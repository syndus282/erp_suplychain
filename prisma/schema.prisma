// 11. LOGISTICS & DELIVERY
// =========================================================================

enum DeliveryRequestStatus {
  DRAFT
  PLANNED
  PICKING
  PACKED
  ON_DELIVERY
  DELIVERED
  CONFIRMED
  FAILED
  CLOSED
}

enum DeliverySourceType {
  SALES_ORDER
  CONSIGNMENT_SHIPMENT
  WARRANTY_REPLACEMENT
  STOCK_TRANSFER
}

enum VehicleStatus {
  AVAILABLE
  ON_DELIVERY
  MAINTENANCE
  INACTIVE
}

enum DeliveryCostType {
  FUEL
  TOLL
  THIRD_PARTY_CARRIER
  LOADING
  OTHER
}

model DeliveryRequest {
  id              String                @id @default(cuid())
  companyId       String
  code            String
  sourceType      DeliverySourceType
  sourceId        String
  customerId      String?
  deliveryAddress String?
  requestedAt     DateTime              @default(now())
  priority        String?
  status          DeliveryRequestStatus @default(DRAFT)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])

  lines         DeliveryRequestLine[]
  shipmentLines ShipmentLine[]

  @@unique([companyId, code])
}

model DeliveryRequestLine {
  id        String  @id @default(cuid())
  requestId String
  productId String
  serialId  String?
  lotId     String?
  qty       Float

  request DeliveryRequest @relation(fields: [requestId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  serial  SerialNumber?   @relation(fields: [serialId], references: [id])
  lot     LotBatch?       @relation(fields: [lotId], references: [id])
}

model Vehicle {
  id          String        @id @default(cuid())
  companyId   String
  plateNumber String        @unique
  type        String?
  capacity    Float?
  status      VehicleStatus @default(AVAILABLE)
  createdAt   DateTime      @default(now())

  shipments Shipment[]
}

model Driver {
  id            String    @id @default(cuid())
  companyId     String
  employeeId    String    @unique
  licenseNo     String?
  licenseType   String?
  licenseExpiry DateTime?

  employee  Employee   @relation(fields: [employeeId], references: [id])
  shipments Shipment[]
}

model Carrier {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  contractNo  String?
  serviceArea String?
  createdAt   DateTime @default(now())

  shipments       Shipment[]
  importShipments ImportShipment[]

  @@unique([companyId, code])
}

model Shipment {
  id          String                @id @default(cuid())
  companyId   String
  code        String
  warehouseId String
  vehicleId   String?
  driverId    String?
  carrierId   String?
  shippedAt   DateTime?
  status      DeliveryRequestStatus @default(DRAFT)
  createdAt   DateTime              @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  vehicle   Vehicle?  @relation(fields: [vehicleId], references: [id])
  driver    Driver?   @relation(fields: [driverId], references: [id])
  carrier   Carrier?  @relation(fields: [carrierId], references: [id])

  lines            ShipmentLine[]
  proofsOfDelivery ProofOfDelivery[]
  costs            DeliveryCost[]

  @@unique([companyId, code])
}

model ShipmentLine {
  id                String @id @default(cuid())
  shipmentId        String
  deliveryRequestId String
  productId         String
  qty               Float

  shipment        Shipment        @relation(fields: [shipmentId], references: [id])
  deliveryRequest DeliveryRequest @relation(fields: [deliveryRequestId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
}

model ProofOfDelivery {
  id             String   @id @default(cuid())
  shipmentId     String
  receivedByName String?
  receivedAt     DateTime @default(now())
  signatureUrl   String?
  photoUrl       String?
  note           String?

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}

model DeliveryCost {
  id         String           @id @default(cuid())
  shipmentId String
  type       DeliveryCostType
  amount     Int
  currency   String           @default("VND")

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}

