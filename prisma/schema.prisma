// 12. WARRANTY, RMA & FIELD SERVICE
// =========================================================================

enum WarrantyClaimStatus {
  OPEN
  INSPECTING
  APPROVED
  REJECTED
  REPAIRING
  REPLACED
  CLOSED
}

enum RmaStatus {
  REQUESTED
  APPROVED
  RECEIVED
  QC_DONE
  REPAIRED
  REPLACED
  REJECTED
}

enum CoreReturnStatus {
  PENDING
  RETURNED
  OVERDUE
  LOST
}

enum RepairOrderStatus {
  RECEIVED
  DIAGNOSING
  REPAIRING
  TESTING
  COMPLETED
  RETURNED
}

enum FieldServiceType {
  INSTALLATION
  MAINTENANCE
  REPAIR
}

enum FieldServiceStatus {
  REQUESTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model WarrantyPolicy {
  id             String  @id @default(cuid())
  companyId      String
  productId      String?
  categoryId     String?
  durationMonths Int
  conditions     String?

  product  Product?         @relation(fields: [productId], references: [id])
  category ProductCategory? @relation(fields: [categoryId], references: [id])
}

model WarrantyRegistration {
  id             String    @id @default(cuid())
  companyId      String
  productId      String
  serialId       String?
  customerId     String
  soId           String?
  vehicleModelId String?
  soldAt         DateTime?
  warrantyStart  DateTime
  warrantyEnd    DateTime

  product      Product       @relation(fields: [productId], references: [id])
  serial       SerialNumber? @relation(fields: [serialId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  salesOrder   SalesOrder?   @relation(fields: [soId], references: [id])
  vehicleModel VehicleModel? @relation(fields: [vehicleModelId], references: [id])

  claims WarrantyClaim[]
}

model WarrantyClaim {
  id             String              @id @default(cuid())
  companyId      String
  code           String
  registrationId String
  customerId     String
  description    String?
  attachmentUrls String?
  status         WarrantyClaimStatus @default(OPEN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  registration WarrantyRegistration @relation(fields: [registrationId], references: [id])
  customer     Customer             @relation(fields: [customerId], references: [id])

  rmaRequests  RmaRequest[]
  repairOrders RepairOrder[]

  @@unique([companyId, code])
}

model RmaRequest {
  id            String    @id @default(cuid())
  companyId     String
  code          String
  claimId       String?
  salesReturnId String?
  status        RmaStatus @default(REQUESTED)
  createdAt     DateTime  @default(now())

  claim       WarrantyClaim? @relation(fields: [claimId], references: [id])
  salesReturn SalesReturn?   @relation(fields: [salesReturnId], references: [id])

  @@unique([companyId, code])
}

model CoreReturn {
  id          String           @id @default(cuid())
  companyId   String
  newSerialId String
  oldSerialId String?
  customerId  String
  deliveredAt DateTime         @default(now())
  dueReturnAt DateTime?
  returnedAt  DateTime?
  status      CoreReturnStatus @default(PENDING)

  newSerial SerialNumber  @relation("CoreReturnNewSerial", fields: [newSerialId], references: [id])
  oldSerial SerialNumber? @relation("CoreReturnOldSerial", fields: [oldSerialId], references: [id])
  customer  Customer      @relation(fields: [customerId], references: [id])
}

model RepairOrder {
  id           String            @id @default(cuid())
  companyId    String
  claimId      String
  technicianId String?
  laborCost    Int               @default(0)
  status       RepairOrderStatus @default(RECEIVED)
  createdAt    DateTime          @default(now())

  claim      WarrantyClaim @relation(fields: [claimId], references: [id])
  technician Employee?     @relation(fields: [technicianId], references: [id])
}

model FieldServiceRequest {
  id           String             @id @default(cuid())
  companyId    String
  code         String
  customerId   String
  technicianId String?
  type         FieldServiceType
  scheduledAt  DateTime?
  status       FieldServiceStatus @default(REQUESTED)
  createdAt    DateTime           @default(now())

  customer   Customer  @relation(fields: [customerId], references: [id])
  technician Employee? @relation(fields: [technicianId], references: [id])

  @@unique([companyId, code])
}

// =========================================================================
// 13. FINANCE & ACCOUNTING
// =========================================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  LOCKED
}

enum PartnerType {
  SUPPLIER
  CUSTOMER
}

enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentDirection {
  IN
  OUT
}

model Account {
  id        String      @id @default(cuid())
  companyId String
  code      String
  name      String
  type      AccountType
  parentId  String?
  createdAt DateTime    @default(now())

  parent   Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[] @relation("AccountHierarchy")

  journalEntryLines JournalEntryLine[]

  @@unique([companyId, code])
}

model JournalEntry {
  id          String             @id @default(cuid())
  companyId   String
  code        String
  date        DateTime
  refType     String?
  refId       String?
  description String?
  status      JournalEntryStatus @default(DRAFT)
  createdAt   DateTime           @default(now())

  lines JournalEntryLine[]

  @@unique([companyId, code])
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Int          @default(0)
  credit         Int          @default(0)
  currency       String       @default("VND")
  exchangeRate   Float        @default(1)
  costCenterId   String?
  partnerType    PartnerType?
  partnerId      String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])
}

model CostCenter {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  createdAt DateTime @default(now())

  journalEntryLines JournalEntryLine[]
  budgets           Budget[]

  @@unique([companyId, code])
}

model SupplierInvoice {
  id           String        @id @default(cuid())
  companyId    String
  code         String
  supplierId   String
  poId         String?
  currency     String        @default("VND")
  exchangeRate Float         @default(1)
  amount       Int
  paidAmount   Int           @default(0)
  dueDate      DateTime?
  status       InvoiceStatus @default(PENDING)
  createdAt    DateTime      @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([companyId, code])
}

model CustomerInvoice {
  id         String        @id @default(cuid())
  companyId  String
  code       String
  customerId String
  soId       String?
  currency   String        @default("VND")
  amount     Int
  paidAmount Int           @default(0)
  dueDate    DateTime?
  status     InvoiceStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  customer   Customer    @relation(fields: [customerId], references: [id])
  salesOrder SalesOrder? @relation(fields: [soId], references: [id])

  @@unique([companyId, code])
}

model Payment {
  id            String           @id @default(cuid())
  companyId     String
  code          String
  direction     PaymentDirection
  partnerType   PartnerType
  partnerId     String
  amount        Int
  currency      String           @default("VND")
  exchangeRate  Float            @default(1)
  method        String?
  bankAccountId String?
  paidAt        DateTime         @default(now())
  refType       String?
  refId         String?

  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@unique([companyId, code])
}

model BankAccount {
  id        String @id @default(cuid())
  companyId String
  bankName  String
  accountNo String
  currency  String @default("VND")

  payments Payment[]

  @@unique([companyId, accountNo])
}

model FixedAsset {
  id               String   @id @default(cuid())
  companyId        String
  code             String
  name             String
  purchaseDate     DateTime
  originalCost     Int
  usefulLifeMonths Int
  currentValue     Int

  @@unique([companyId, code])
}

model Budget {
  id            String  @id @default(cuid())
  companyId     String
  departmentId  String?
  costCenterId  String?
  period        String
  category      String
  plannedAmount Int
  currency      String  @default("VND")

  department Department? @relation(fields: [departmentId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])
}

// =========================================================================
// 14. HRM & PAYROLL
// =========================================================================

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  SPECIAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  CONFIRMED
  PAID
}

model EmploymentContract {
  id         String    @id @default(cuid())
  employeeId String
  type       String?
  startDate  DateTime
  endDate    DateTime?
  baseSalary Int
  currency   String    @default("VND")

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Shift {
  id        String @id @default(cuid())
  companyId String
  name      String
  startTime String
  endTime   String

  attendanceRecords AttendanceRecord[]
}

model AttendanceRecord {
  id         String    @id @default(cuid())
  employeeId String
  shiftId    String?
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  otHours    Float     @default(0)

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, date])
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  type       LeaveType
  fromDate   DateTime
  toDate     DateTime
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id                 String        @id @default(cuid())
  companyId          String
  employeeId         String
  period             String
  baseSalary         Int
  allowance          Int           @default(0)
  bonus              Int           @default(0)
  commission         Int           @default(0)
  otAmount           Int           @default(0)
  insuranceDeduction Int           @default(0)
  taxDeduction       Int           @default(0)
  netAmount          Int
  currency           String        @default("VND")
  status             PayrollStatus @default(DRAFT)

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, period])
}

model CommissionRecord {
  id         String  @id @default(cuid())
  employeeId String
  soId       String?
  amount     Int
  currency   String  @default("VND")
  period     String

  employee   Employee    @relation(fields: [employeeId], references: [id])
  salesOrder SalesOrder? @relation(fields: [soId], references: [id])
}

// =========================================================================
// 15. WORKFLOW / APPROVAL (cross-cutting, đa hình)
// =========================================================================

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
}

model ApprovalMatrix {
  id              String @id @default(cuid())
  companyId       String
  transactionType String
  minAmount       Int    @default(0)
  maxAmount       Int?
  approverRoleId  String

  approverRole Role @relation(fields: [approverRoleId], references: [id])
}

model ApprovalRequest {
  id            String         @id @default(cuid())
  companyId     String
  entityType    String
  entityId      String
  requestedById String
  status        ApprovalStatus @default(PENDING)
  currentStep   Int            @default(1)
  createdAt     DateTime       @default(now())

  steps ApprovalStep[]
}

model ApprovalStep {
  id                String             @id @default(cuid())
  approvalRequestId String
  stepOrder         Int
  approverRoleId    String?
  approverUserId    String?
  status            ApprovalStepStatus @default(PENDING)
  actedAt           DateTime?
  comment           String?

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id])
  approverRole    Role?           @relation(fields: [approverRoleId], references: [id])
  approverUser    User?           @relation(fields: [approverUserId], references: [id])
}

model AuditLog {
  id          String      @id @default(cuid())
  companyId   String
  entityType  String
  entityId    String
  action      AuditAction
  changedById String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime    @default(now())

  changedBy User? @relation(fields: [changedById], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  type      String
  title     String
  message   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
